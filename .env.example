# Copy this file to `.env` and fill in the values you need.
# Variables already present in the process environment take precedence
# over values in `.env`.

# --- Provider selection (used by the CLI and the FastAPI gateway) ---
# anthropic | openai | gemini
LLM_PROVIDER=anthropic

# --- API keys (set the ones for the providers you intend to use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Optional model overrides ---
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4.1
GEMINI_MODEL=gemini-2.5-flash

# --- Optional: point at a non-default .env path ---
# BOTCIRCUITS_ENV_FILE=/absolute/path/to/.env

# --- Messaging gateway: WhatsApp (Meta Cloud API) ---
# Mounts inbound webhook at  /messaging/whatsapp  (GET verify + POST events).
# Leave any one unset to skip the WhatsApp channel.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_GRAPH_VERSION=v20.0

# --- Messaging gateway: Slack (Socket Mode) ---
# Opens an outbound WebSocket to Slack — no public URL required.
# Bot token (xoxb-…) is used for chat.postMessage; app-level token
# (xapp-…) needs the `connections:write` scope and is used to open the
# socket. Leave either unset to skip the Slack channel.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Messaging gateway: generic webhook ---
# Inbound:  POST /messaging/webhook  {"chat_id","text"} (Bearer token if set).
# Outbound: replies are POSTed to WEBHOOK_OUTBOUND_URL when set.
WEBHOOK_OUTBOUND_URL=
WEBHOOK_TOKEN=
