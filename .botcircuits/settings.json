{
  "stream": true,
  "max_tokens": 4096,
  "max_steps": 500,
  "show_tool_results": false,
  "tools": {
    "shell_exec": {
      "timeout_seconds": 30,
      "max_output_bytes": 10000
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(git status)",
      "Bash(npm run *)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(~/.ssh/**)",
      "Bash(rm -rf *)"
    ]
  }
}
